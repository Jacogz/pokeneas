<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Pokénea</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background: #f2f2f2;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }
        .card {
            max-width: 900px;
            width: 100%;
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 32px;
            padding: 40px;
        }
        .image-box {
            background: #f5f5f5;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            min-height: 320px;
        }
        .image-box img {
            max-width: 100%;
            max-height: 360px;
            border-radius: 8px;
        }
        .frase {
            display: flex;
            align-items: center;
            font-size: 20px;
            line-height: 1.5;
            color: #2a2a2a;
            font-style: italic;
        }
        @media (max-width: 720px) {
            .card { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="image-box">
            <img src="<%= image %>" alt="Pokénea">
        </div>
        <p class="frase">"<%= frase %>"</p>
    </div>
</body>
</html>
